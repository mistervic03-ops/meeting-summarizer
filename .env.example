# Current baseline providers.
STT_PROVIDER=openai
SUMMARIZATION_PROVIDER=openai

# Required while STT_PROVIDER=openai or SUMMARIZATION_PROVIDER=openai.
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI STT settings.
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_DIARIZED_TRANSCRIPTION_MODEL=gpt-4o-transcribe-diarize
OPENAI_TRANSCRIPTION_LANGUAGE=ko
TRANSCRIPTION_MODE=plain
ENABLE_DIARIZED_TRANSCRIPTION=false
PLAIN_TRANSCRIPTION_CONCURRENCY=3
PLAIN_CHUNK_DURATION_SECONDS=300
PLAIN_CHUNK_OVERLAP_SECONDS=0
DIARIZED_CHUNK_DURATION_SECONDS=150
DIARIZED_CHUNK_OVERLAP_SECONDS=0
ENABLE_STT_VOCABULARY_HINTS=true
STT_VOCABULARY_PATH=config/stt_vocabulary.yaml

# OpenAI summarization settings.
OPENAI_STRUCTURE_MODEL=gpt-4o-mini
OPENAI_SUMMARY_MODEL=gpt-5.4

# Future providers. Leave unset until those paths are implemented.
# STT_PROVIDER=local_whisper
# SUMMARIZATION_PROVIDER=claude
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Backend CORS. Add Spark server URLs only if the frontend calls the API directly.
# Example: CORS_ORIGINS=http://localhost:5173,http://192.168.3.41:5173
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# Frontend build/runtime setting. Vite reads this from the frontend process env or frontend/.env.
# Vite defaults to /api when this is unset.
# Example for direct backend calls: VITE_API_BASE_URL=http://192.168.3.41:8000/api
VITE_API_BASE_URL=/api
