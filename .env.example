# Current baseline providers.
# Local GPU Whisper is the normal internal STT path on Spark/GB10.
STT_PROVIDER=local_gpu_whisper
SUMMARIZATION_PROVIDER=openai

# Required for OpenAI summarization and for the advanced OpenAI API STT mode.
OPENAI_API_KEY=your_openai_api_key_here
SESSION_SECRET=your-secret-key-change-me-in-production

# Gateway password auth. Defaults match the shared Spark account and compose mount.
# GATEWAY_AUTH_SECRET falls back to SESSION_SECRET when unset.
# GATEWAY_AUTH_USERNAME=bigxdata
# GATEWAY_HTPASSWD_PATH=secrets/.htpasswd

# OpenAI model names below are unversioned aliases that automatically follow stable releases.
# No manual model update is needed for gpt-4o-mini, gpt-5.4, or gpt-4o-transcribe.
# OpenAI STT settings. Used by the advanced/cloud UI mode.
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_DIARIZED_TRANSCRIPTION_MODEL=gpt-4o-transcribe-diarize
OPENAI_TRANSCRIPTION_LANGUAGE=ko
TRANSCRIPTION_MODE=plain
ENABLE_DIARIZED_TRANSCRIPTION=false

# Plain STT chunking. Keep 300s for the current local GPU baseline.
PLAIN_TRANSCRIPTION_CONCURRENCY=3
PLAIN_CHUNK_DURATION_SECONDS=300
PLAIN_CHUNK_OVERLAP_SECONDS=0
DIARIZED_CHUNK_DURATION_SECONDS=150
DIARIZED_CHUNK_OVERLAP_SECONDS=0

# STT glossary/prompt bias is disabled for the current local GPU baseline.
ENABLE_STT_VOCABULARY_HINTS=false
STT_VOCABULARY_PATH=config/stt_vocabulary.yaml

# Diarized transcription remains in backend code for legacy/experimental review,
# but the user-facing default path is local GPU plain STT.

# OpenAI summarization settings.
OPENAI_STRUCTURE_MODEL=gpt-4o-mini
OPENAI_SUMMARY_MODEL=gpt-5.4

# Claude summarization settings. Used only when SUMMARIZATION_PROVIDER=claude.
# Claude model IDs are pinned snapshots, not evergreen aliases.
# Manually update these values when Anthropic releases a newer desired version:
# https://docs.anthropic.com/en/docs/about-claude/models/overview
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_STRUCTURE_MODEL=claude-sonnet-4-6
CLAUDE_SUMMARY_MODEL=claude-sonnet-4-6

# Other providers. Leave unset unless explicitly testing these paths.
# STT_PROVIDER=local_whisper
# SUMMARIZATION_PROVIDER=claude

# Local Whisper CPU settings. Used only when STT_PROVIDER=local_whisper.
LOCAL_WHISPER_MODEL=small
LOCAL_WHISPER_DEVICE=cpu
LOCAL_WHISPER_COMPUTE_TYPE=int8
LOCAL_WHISPER_LANGUAGE=ko

# Local GPU Whisper settings. Used only when STT_PROVIDER=local_gpu_whisper.
# Requires the validated NGC PyTorch runtime with torch/transformers installed.
# Defaults are built into the app; do not override the model for normal operation.
# LOCAL_GPU_WHISPER_MODEL=openai/whisper-large-v3-turbo
LOCAL_GPU_DEVICE=cuda:0
LOCAL_GPU_TORCH_DTYPE=float16
LOCAL_GPU_MAX_CONCURRENCY=3
LOCAL_GPU_ENABLE_STT_PROMPT=false

# Backend CORS. Production frontend calls the API through the same-origin nginx /api proxy.
# Example: CORS_ORIGINS=http://localhost:5173,http://192.168.3.41:5173
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# Frontend build/runtime setting. Vite reads this from the frontend process env or frontend/.env.
# Vite defaults to /api when this is unset. Production should use this same-origin /api path.
# Do not point production frontend directly at http://192.168.3.41:8000/api; backend 8000 is not published on the host.
VITE_API_BASE_URL=/api
